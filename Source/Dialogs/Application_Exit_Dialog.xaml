<UserControl x:Class="Oracle_Lite.Dialogs.Application_Exit_Dialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Oracle_Lite.Dialogs"
             mc:Ignorable="d" FontFamily="Philosopher" FontSize="18" FontWeight="Bold"
             MinWidth="700" MinHeight="500" Foreground="Black">
    <Border CornerRadius="5" Background="#3F000000">
        <Grid>
            <Border CornerRadius="10" HorizontalAlignment="Center" VerticalAlignment="Center" Width="500" Height="200" Background="#FFF2F5FA">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Are you sure you want to exit?" HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" Margin="0,20,0,0" HorizontalAlignment="Center">
                        <Button x:Name="ButtonYes" Content="Yes" Style="{DynamicResource ButtonStyle3}" Click="ButtonYes_Click"/>
                        <Button x:Name="ButtonNo" Content="No" Style="{DynamicResource ButtonStyle4}" Margin="10,0,0,0" Click="ButtonNo_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
