<UserControl x:Class="Oracle_Lite.Dialogs.Game_Finder_Dialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Oracle_Lite.Dialogs"
             mc:Ignorable="d" FontFamily="Philosopher" FontSize="18" FontWeight="Bold"
             MinWidth="700" MinHeight="500" Foreground="Black">
    <Border CornerRadius="5" Background="#3F000000">
        <Grid>
            <Border CornerRadius="10" HorizontalAlignment="Center" VerticalAlignment="Center" Width="500" Height="220" Background="#FFF2F5FA">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Select your game destination" HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" Margin="0,20,0,0" HorizontalAlignment="Center">
                        <Button x:Name="ButtonBrowse" Content="Browse" Style="{DynamicResource ButtonStyle3b}" Click="ButtonBrowse_Click"/>
                        <Button x:Name="ButtonNo" Content="Cancel" Style="{DynamicResource ButtonStyle4}" Margin="10,0,0,0" Click="ButtonNo_Click"/>
                    </StackPanel>
                    <TextBlock Margin="0,20,0,0" HorizontalAlignment="Center" Foreground="#FF444444" FontWeight="Normal" FontStyle="Italic" FontSize="15">
                        <Run Text="Selected path:"/>
                        <Run x:Name="pathHolder" Text="C:\Users\cybermist2\Downloads"/>
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
