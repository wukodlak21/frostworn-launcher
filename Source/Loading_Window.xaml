<Window x:Class="Oracle_Lite.Loading_Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Oracle_Lite"
        mc:Ignorable="d" AllowsTransparency="True"
        WindowStartupLocation="CenterScreen" WindowStyle="None"
        ResizeMode="CanMinimize" RenderOptions.BitmapScalingMode="HighQuality"
        Title="Oracle Lite" Height="250" Width="400" Background="{x:Null}"
        Foreground="White" FontFamily="Philosopher" FontSize="15" Loaded="Window_Loaded">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="50" ResizeBorderThickness="1" GlassFrameThickness="0" CornerRadius="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>
    <Border CornerRadius="10" BorderThickness="0.5" BorderBrush="White">
        <Border.Background>
            <ImageBrush ImageSource="/Oracle Lite;component/Resources/loading_window_background.jpg" Stretch="UniformToFill"/>
        </Border.Background>
        <Grid>
            <Border CornerRadius="10" Background="#99000000"/>
            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="powered by" HorizontalAlignment="Center" FontSize="12"/>
                <TextBlock Text="ORACLE LITE" FontWeight="Bold" FontSize="24"/>
            </StackPanel>
            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,25">
                <TextBlock Text="Loading important data, please be patient.." HorizontalAlignment="Center"/>
                <ProgressBar x:Name="LoadingBar" Margin="0,10,0,0" Height="10" Background="#FF1F2E3C" BorderBrush="{x:Null}" BorderThickness="0,0,0,0" Style="{DynamicResource ProgressBarStyle1}" Width="350"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
