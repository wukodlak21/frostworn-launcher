<UserControl x:Class="Oracle_Lite.Popups.Submenu_Popup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Oracle_Lite.Popups"
             mc:Ignorable="d" FontFamily="Philosopher" FontWeight="SemiBold" Foreground="Black">
    <Border CornerRadius="10" Background="White" Padding="25,10,25,5" MaxWidth="250">
        <StackPanel Orientation="Vertical">
            <Button x:Name="ButtonDiscord" Content="Discord" Style="{DynamicResource SubmenuButton}" Click="ButtonDiscord_Click"/>
            <Button x:Name="ButtonFacebook" Content="Facebook" Style="{DynamicResource SubmenuButton}" Click="ButtonFacebook_Click"/>
            <Button x:Name="ButtonTwitter" Content="Twitter" Style="{DynamicResource SubmenuButton}" Click="ButtonTwitter_Click"/>
            <Button x:Name="ButtonInstagram" Content="Instagram" Style="{DynamicResource SubmenuButton}" Click="ButtonInstagram_Click"/>
        </StackPanel>
    </Border>
</UserControl>
